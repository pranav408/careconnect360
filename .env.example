SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:mysql://localhost:3307/careconnect360?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=<LOCAL_DB_USERNAME>
DB_PASSWORD=<LOCAL_DB_PASSWORD>
JWT_SECRET=<GENERATE_A_LONG_RANDOM_SECRET>
JWT_EXPIRATION_MS=3600000
ADMIN_EMAIL=admin@careconnect360.com
ADMIN_PASSWORD=<LOCAL_ADMIN_PASSWORD>
SERVER_PORT=8080
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=false
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_DOCS_ENABLED=true
APP_ADMIN_BOOTSTRAP_ENABLED=false
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MYSQL_DATABASE=careconnect360
MYSQL_USER=<LOCAL_DB_USERNAME>
MYSQL_PASSWORD=<LOCAL_DB_PASSWORD>
MYSQL_ROOT_PASSWORD=<LOCAL_ROOT_PASSWORD>
MYSQL_HOST_PORT=3307
